{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,
    
    "modules-left": [
        "custom/separator_space",
        "custom/logo",
        "custom/separator",
        "cpu",
        "custom/separator",
        "memory"
    ],

    "modules-center": [
        "sway/workspaces"
    ],

    "modules-right": [
       // "custom/music_track",
     //   "custom/separator",
        "clock",
        "custom/separator_space"
    ],

    "custom/logo": {
        "format": "  ",
        "tooltip": false,
        "on-click": "pkill wofi || ~/.local/bin/wofi-powermenu"
    },

    "custom/separator": {
        "format": " | ",
        "tooltip": false
    },

    "custom/separator_space": {
        "format": " ",
        "tooltip": false
    },

    "cpu": {
        "format": "CPU: {usage}%",
        "tooltip": false
    },

    "memory": {
        "format": "RAM: {percentage}%",
        "tooltip": true
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },

