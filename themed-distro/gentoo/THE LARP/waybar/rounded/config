{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,
    
    "modules-left": ["custom/logo", "cpu", "memory", "custom/gpu"],
    "modules-center": ["sway/workspaces"],
    "modules-right": ["sway/language", "custom/weather", "clock"],

    "custom/logo": {
        "format": "",
        "tooltip": false,
        "on-click": "pkill wofi || ~/.local/bin/wofi-powermenu"
    },

    "cpu": {
        "format": "  {usage}%",
        "interval": 2
    },
    "memory": {
        "format": "  {percentage}%",
        "interval": 2,
        "tooltip-format": "Использовано: {used:0.1f}GB / {total:0.1f}GB"
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },

    "sway/language": {
        "format": "{}"
    },

	"clock": {
	        "timezone": "local",
	        "format": "{:%Y-%m-%d    %H:%M:%S}",
	        "interval": 1,
	        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
	    },
}
